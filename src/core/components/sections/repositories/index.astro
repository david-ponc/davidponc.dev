---
import { getLocale, getTranslations } from "~/i18n";
import Repository from "./repository.astro";
import { repositories } from "~/data/repositories";
import WireNode from "../../ui/wire/wire-node.astro";
import Button from "../../ui/button";
import ArrowTopRightOnSquareIcon from "~/assets/arrow-top-right-on-square.svg";
import { reveal } from "~/core/animations/transitions";

const lang = getLocale(Astro.currentLocale);
const t = getTranslations(lang);

const localizedRepositories = repositories.map((repository) => ({
  ...repository,
  ...t.repositories.repositories[repository.key],
}));
---

<section
  class="@container/repositories flex min-h-[75dvh] items-center justify-center"
>
  <div
    class="z-1 mx-auto flex flex-col w-full max-w-6xl gap-12 px-4 @6xl/repositories:px-0"
  >
    <header class="relative">
      <h2
        id="repositories"
        class="text-2xl font-medium text-muted-foreground"
        transition:animate={reveal}
      >
        {t.repositories.heading}
      </h2>
    </header>

    <section
      id="glow-container"
      class="glow-container relative grid grid-cols-[repeat(auto-fit,minmax(20rem,1fr))] gap-4"
    >
      <WireNode class="top-1/2 -left-2" />
      <WireNode class="top-1/2 left-6" />
      <WireNode class="top-1/2 -left-2" />
      {
        localizedRepositories.map((repository) => (
          <Repository {...repository} />
        ))
      }
    </section>
    <footer class="-mt-7 flex items-center justify-end">
      <Button
        as="a"
        size="inline"
        target="_blank"
        href="https://github.com/david-ponc?tab=repositories"
        variant="link"
        rel="noopener noreferrer"
        class="gap-1"
        transition:animate={reveal}
      >
        {t.repositories.actions.viewAll}
        <ArrowTopRightOnSquareIcon class="size-4" />
      </Button>
    </footer>
  </div>
</section>

<script>
  let container: HTMLElement | null = null;

  function onMouseMove(e: MouseEvent) {
    if (!container) return;
    const cards = container.querySelectorAll<HTMLElement>(".glow-card");
    cards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
      card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
    });
  }

  function setup() {
    container = document.getElementById("glow-container");
    if (container) {
      container.addEventListener("mousemove", onMouseMove);
    }
  }

  function teardown() {
    if (container) {
      container.removeEventListener("mousemove", onMouseMove);
      container = null;
    }
  }

  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:before-swap", teardown);
</script>

---
import { getLocale, getTranslations } from "~/i18n";

const lang = getLocale(Astro.currentLocale);
const t = getTranslations(lang);
---

<section class="flex min-h-[75dvh] items-center justify-center">
  <div class="z-1 mx-auto flex flex-col w-full max-w-6xl gap-24">
    <header class="relative">
      <h2 id="projects" class="text-2xl font-medium text-muted-foreground">
        {t.projects.heading}
      </h2>
    </header>
  </div>
</section>
